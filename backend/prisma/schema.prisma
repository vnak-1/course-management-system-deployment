generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  role UserRole @default(student)
  createdAt DateTime @default(now())

  // db relationship
  lessonProgress LessonProgress[]  // one user can have many lesson progress on track
  enrolments Enrolment[]  // one user can have many enrolments course
}

model Course {
  id String @id @default(uuid())
  title String
  description String
  price Decimal @db.Decimal(10, 2)
  thumbnail String
  discount Decimal @default(0) @db.Decimal(10, 2)
  discountQuantity Int @default(0)
  createdAt DateTime @default(now())

  // db relationship
  lessons Lesson[]  // one course can have many lessons
  enrolments Enrolment[]  // one course can have many users' enrolments
}

model Lesson {
  id String @id @default(uuid())
  courseId String
  title String
  description String?
  videoUrl String

  // db relationship
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)  // if course is deleted, the lessons inside it shall be deleted as well
  userProgress LessonProgress[]  // one lesson can have different lesson progress tracker
}

model Enrolment {
  id String @id @default(uuid())
  userId String
  courseId String
  priceAtSale Decimal @db.Decimal(10, 2)
  status EnrolmentStatus @default(pending)  
  progress Decimal @db.Decimal(10, 2)
  enrolledAt DateTime @default(now())

  // db relationship
    // no cascade on delete, because we must save this data info to do sales overview in the ADMIN Dashboard
  user User @relation(fields: [userId], references: [id]) 
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])  // prevent double enrolment for the same course
}

model LessonProgress {
  id String @id @default(uuid())
  userId String
  lessonId String
  isCompleted Boolean @default(false)

  // db relationship
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])  // one record per user per lesson
}

enum UserRole {
  admin
  student
}

enum EnrolmentStatus {
  pending
  success
  cancelled
}
